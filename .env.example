# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Kakao OAuth ───────────────────────────────────────────────────────
# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=your-kakao-rest-api-key
# 카카오 개발자 콘솔 → 카카오 로그인 → Redirect URI에 동일하게 등록
KAKAO_REDIRECT_URI=http://localhost:8501

# ── Kakao Band API (선택) ─────────────────────────────────────────────
BAND_ACCESS_TOKEN=your-band-access-token
BAND_KEY=your-band-key

# ── App Settings ──────────────────────────────────────────────────────
CLUB_ID=your-club-uuid-from-supabase
